# ServiceMatrix 環境変数定義例
# 本番環境では適切な値に変更すること

# データベース
DATABASE_URL=postgresql+asyncpg://servicematrix:password@localhost:5432/servicematrix
POSTGRES_DB=servicematrix
POSTGRES_USER=servicematrix
POSTGRES_PASSWORD=change-this-strong-password

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=change-this-redis-password

# JWT認証
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# アプリケーション設定
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO
APP_NAME=ServiceMatrix
APP_VERSION=1.0.0

# CORS設定
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# 監査ログ設定
AUDIT_LOG_RETENTION_YEARS=7

# GitHub連携設定
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_TOKEN=ghp_your-personal-access-token
GITHUB_REPO=owner/repository-name

# AI/LLM設定
LLM_PROVIDER=keyword  # keyword | openai | azure_openai | ollama
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_API_BASE=  # Azure OpenAI エンドポイントまたはOllamaのURL

# アラート・通知設定
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
ALERT_WEBHOOK_ENABLED=false
