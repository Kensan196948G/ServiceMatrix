{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": []
  },
  "description": "ServiceMatrix ITSM KPI ダッシュボード",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "インシデント作成数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "servicematrix_incidents_created_total",
          "legendFormat": "インシデント",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "変更リクエスト数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "servicematrix_changes_created_total",
          "legendFormat": "変更",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "SLA 違反数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "targets": [
        {
          "expr": "servicematrix_sla_breaches_total",
          "legendFormat": "SLA違反",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "WebSocket 接続数",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "blue", "value": null }
            ]
          }
        }
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value"
      },
      "targets": [
        {
          "expr": "servicematrix_ws_connections_active",
          "legendFormat": "WS接続",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "ITSM KPI トレンド",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        }
      },
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "expr": "servicematrix_incidents_created_total",
          "legendFormat": "インシデント累計",
          "refId": "A"
        },
        {
          "expr": "servicematrix_changes_created_total",
          "legendFormat": "変更累計",
          "refId": "B"
        },
        {
          "expr": "servicematrix_sla_breaches_total",
          "legendFormat": "SLA違反累計",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "AI トリアージ呼び出し数",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 5,
            "lineStyle": { "fill": "dash" }
          },
          "color": { "mode": "palette-classic" }
        }
      },
      "options": {
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "targets": [
        {
          "expr": "rate(servicematrix_ai_triage_calls_total[5m])",
          "legendFormat": "AI トリアージ呼び出し rate/5m",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "tags": ["servicematrix", "itsm", "kpi", "sla"],
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "Asia/Tokyo",
  "title": "ServiceMatrix - ITSM KPI",
  "uid": "sm-itsm-kpi",
  "version": 1
}
